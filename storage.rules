rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /orders/{orderId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && firestore.get(/databases/(default)/documents/orders/$(orderId)).data.traderId == request.auth.uid;
    }
  }
}
